# ========================================
# OKX API credentials (sub-account)
# ========================================
# Получить на https://www.okx.com → Profile → API → Create V5 API Key
# Права: только Trade. Withdraw — выключить. Включить IP whitelist на свой IP.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# Использовать testnet OKX (true/false). На Этапе 0/1 можно false — мы не торгуем.
OKX_USE_TESTNET=false

# ========================================
# Telegram (понадобится на Этапе 4)
# ========================================
# Создать бота: написать @BotFather в Telegram → /newbot
TELEGRAM_BOT_TOKEN=
# Узнать chat_id: написать боту любое сообщение, потом открыть
# https://api.telegram.org/bot<TOKEN>/getUpdates и найти "chat":{"id": ...}
TELEGRAM_CHAT_ID=

# ========================================
# Режим работы
# ========================================
# live | paper | signals_only
# - signals_only: только лог сигналов в консоль/БД (Этап 1)
# - paper: виртуальный исполнитель ордеров (Этап 2)
# - live: реальная торговля (Этап 3+)
BOT_MODE=signals_only

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
